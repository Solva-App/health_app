<html>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <style>
      body {
        margin: 0;
        padding: 0;
        font-family: Arial, sans-serif;
        background-color: #eef2f8;
        color: #1d1d1d;
      }
      .wrapper {
        width: 100%;
        padding: 24px 0;
      }
      .container {
        width: 100%;
        max-width: 500px;
        margin: 0 auto;
        background: #ffffff;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
      }
      .header {
        background: #173f6f;
        color: #ffffff;
        text-align: center;
        padding: 30px;
      }
      .content {
        padding: 30px;
        text-align: center;
        line-height: 1.6;
      }
      .otp-code {
        font-size: 36px;
        font-weight: bold;
        letter-spacing: 8px;
        color: #173f6f;
        margin: 20px 0;
        padding: 15px;
        background: #f0f7ff;
        border-radius: 12px;
        display: inline-block;
        min-width: 200px;
      }
      .footer {
        padding: 20px;
        font-size: 12px;
        color: #6b6b6b;
        text-align: center;
        border-top: 1px solid #e5e9ef;
      }
    </style>
  </head>
  <body>
    <div class='wrapper'>
      <div class='container'>
        <div class='header'>
          <h2 style='margin:0;'>Reset Password</h2>
        </div>
        <div class='content'>
          <p>Hello <strong>{{fullName}}</strong>,</p>
          <p>We received a request to reset your password for your Marvis Health Tech account. Use the code below to
            proceed:</p>
          <div class='otp-code'>{{otpCode}}</div>
          <p style='font-size: 14px; color: #666;'>This code is valid for
            <strong>{{expiryMinutes}} minutes</strong>.</p>
          <p style='font-size: 13px; color: #e74c3c; margin-top: 25px;'>If you did not request a password reset, please
            secure your account immediately.</p>
        </div>
        <div class='footer'>
          <strong>Marvis Health Tech</strong><br />
          Reliable Pharmacy & Diagnostic Services
        </div>
      </div>
    </div>
  </body>
</html>